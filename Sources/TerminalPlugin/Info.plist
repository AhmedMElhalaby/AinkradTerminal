<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key><string>com.ainkrad.plugin.terminal</string>
    <key>CFBundleName</key><string>TerminalPlugin</string>
    <!-- Required: the host installer renames the bundle to <appID>.bundle
         (terminal.bundle), so CFBundle's filename-based executable fallback
         ("terminal") would miss the real executable. Declare it explicitly. -->
    <key>CFBundleExecutable</key><string>TerminalPlugin</string>
    <key>CFBundlePackageType</key><string>BNDL</string>
    <key>NSPrincipalClass</key><string>TerminalEntryPoint</string>
    <key>AinkradAppID</key><string>terminal</string>
    <key>AinkradDisplayName</key><string>Terminal</string>
    <key>AinkradIconSymbol</key><string>terminal</string>
    <key>AinkradAPIVersion</key><integer>3</integer>
</dict>
</plist>
